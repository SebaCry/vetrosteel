---
import '@fontsource/cinzel/400.css';
import '@fontsource/cinzel/500.css';
import '@fontsource/cinzel/600.css';
import '@fontsource/cinzel/700.css';
import '@fontsource-variable/montserrat';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vetro Steel Design Studio LLC — Precision Stainless Steel & Glass',
  description = 'Industrial design, technical modeling and architectural solutions in stainless steel and glass. We turn concepts into projects ready for fabrication and installation. Utah, USA.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0f3b46" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />

    <script>
      // Scroll-reveal — respects reduced motion via CSS.
      const items = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        items.forEach((el) => io.observe(el));
      } else {
        items.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
