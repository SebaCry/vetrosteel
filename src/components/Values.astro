---
import { Icon } from 'astro-icon/components';

const values = [
  { icon: 'lucide:crosshair', title: 'Precision', body: 'High technical standards to guarantee accuracy in every design, model and component we supply.' },
  { icon: 'lucide:lightbulb', title: 'Innovation', body: 'Modern steel and glass solutions that combine functionality, aesthetics and constructive efficiency.' },
  { icon: 'lucide:shield-check', title: 'Commitment', body: 'We take on every project with responsibility and follow-through, understanding each detail on site.' },
  { icon: 'lucide:gem', title: 'Premium Quality', body: 'High-end materials and processes for durable, reliable and visually flawless results.' },
  { icon: 'lucide:handshake', title: 'Trust', body: 'Solid relationships with architects, contractors and partners, built on transparency and professionalism.' },
  { icon: 'lucide:gauge', title: 'Efficiency', body: 'Optimized technical and logistical processes to execute projects without setbacks or delays.' },
  { icon: 'lucide:sparkles', title: 'Excellence', body: 'We exceed expectations at every stage, from the initial concept to the final installation.' },
];
---

<section id="values" class="relative bg-paper text-ink py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-deep-teal/12 border border-deep-teal/12">
      <!-- header cell -->
      <div class="bg-paper p-8 sm:p-9 flex flex-col justify-center" data-reveal>
        <p class="eyebrow text-teal mb-5 flex items-center gap-3">
          <span class="inline-block w-8 h-px bg-sand rule-draw"></span>
          Values
        </p>
        <h2 class="font-display font-semibold text-3xl sm:text-4xl leading-[1.1] text-deep-teal">
          What holds every project together
        </h2>
      </div>

      {values.map((v, i) => (
        <article
          class="bg-paper p-8 sm:p-9 hover:bg-white transition-colors duration-300 group"
          data-reveal
          style={`--reveal-delay:${(i % 4) * 80}ms`}
        >
          <div class="w-11 h-11 flex items-center justify-center border border-sand/50 group-hover:bg-deep-teal group-hover:border-deep-teal transition-colors duration-300">
            <Icon name={v.icon} class="w-5 h-5 text-sand group-hover:text-sand transition-colors" />
          </div>
          <h3 class="mt-5 font-display text-lg font-semibold text-deep-teal tracking-wide">{v.title}</h3>
          <p class="mt-2.5 text-sm leading-relaxed text-ink/60">{v.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
