---
import { Icon } from 'astro-icon/components';

const services = [
  { icon: 'lucide:drafting-compass', title: 'Technical Plans & Shop Drawings', body: 'Fabrication-ready shop documentation, with tolerances and details verified to install without surprises.' },
  { icon: 'lucide:layers', title: 'Stainless Steel & Glass Design', body: 'Development of parts and systems that balance aesthetics, structural strength and constructive efficiency.' },
  { icon: 'lucide:box', title: 'Architectural Modeling', body: 'Precise 3D models that anticipate clashes and communicate the project before anything is fabricated.' },
  { icon: 'lucide:workflow', title: 'Project Coordination', body: 'We link design, shop and installation so every component reaches the site exactly when it is needed.' },
  { icon: 'lucide:clipboard-check', title: 'Technical Consulting', body: 'Specialized guidance on materials, connections and feasibility for sound decisions from day one.' },
  { icon: 'lucide:truck', title: 'Strategic Supply Support', body: 'Sourcing of premium components through our partner network, optimizing both cost and lead time.' },
];
---

<section id="services" class="relative bg-deep-teal text-warm-gray py-24 sm:py-32 overflow-hidden">
  <div class="absolute inset-0 blueprint-grid opacity-30"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-reveal>
      <div class="max-w-xl">
        <p class="eyebrow text-sand mb-6 flex items-center gap-3">
          <span class="inline-block w-9 h-px bg-sand rule-draw"></span>
          Services
        </p>
        <h2 class="font-display font-semibold text-4xl sm:text-5xl leading-[1.1] text-warm-gray">
          Technical precision, end to end
        </h2>
      </div>
      <p class="max-w-sm text-warm-gray/60 text-base leading-relaxed">
        One partner to carry your project from the first concept to the
        installed component.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10 border border-white/10">
      {services.map((s, i) => (
        <article
          class="relative bg-deep-teal p-8 sm:p-10 group hover:bg-teal transition-colors duration-400 tick-frame"
          data-reveal
          style={`--reveal-delay:${(i % 3) * 100}ms`}
        >
          <span class="absolute top-6 right-7 font-display text-sm text-sand/40 group-hover:text-sand/70 transition-colors">
            0{i + 1}
          </span>
          <Icon name={s.icon} class="w-8 h-8 text-sand" />
          <h3 class="mt-6 font-display text-xl font-semibold text-warm-gray leading-snug tracking-wide">
            {s.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-warm-gray/65">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
