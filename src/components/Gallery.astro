---
const items = [
  { img: '/images/arch/tower-1.jpg', label: 'Facade Study', note: 'Architectural elevation with strong vertical rhythm.' },
  { img: '/images/arch/tower-2.jpg', label: 'Curtain Walls & Facades', note: 'Stainless steel and structural glass envelopes.' },
  { img: '/images/arch/about.jpg', label: 'Material Detail', note: 'A closer look at the steel and glass language.' },
  { img: '/images/arch/imagen18.jpg', label: 'Circulation', note: 'Receding geometry that guides movement and light.' },
  { img: '/images/arch/dome.jpg', label: 'Skylights & Canopies', note: 'Framed glass roofs engineered for light and load.' },
  { img: '/images/arch/mission.jpg', label: 'Mission Space', note: 'Atmospheric architecture with depth and texture.' },
  { img: '/images/arch/imagen7.jpg', label: 'Entry Volumes', note: 'Architectural forms that set the tone from the start.' },
  { img: '/images/arch/imagen8.JPG', label: 'Precision Details', note: 'Clean connections and refined edge conditions.' },
  { img: '/images/arch/imagen9.jpg', label: 'Structural Perspective', note: 'Lines, rhythm and load paths aligned.' },
  { img: '/images/arch/imagen10.jpg', label: 'Technical Modeling', note: 'Drawings translated into buildable geometry.' },
  { img: '/images/arch/imagen11.JPG', label: 'Material Contrast', note: 'Steel and glass working together in balance.' },
  { img: '/images/arch/imagen13.jpg', label: 'Field Assembly', note: 'Pieces prepared for efficient installation.' },
  { img: '/images/arch/imagen14.jpg', label: 'Interior Light', note: 'Openings that bring daylight into the structure.' },
  { img: '/images/arch/imagen17.jpg', label: 'Final Presence', note: 'A polished result that reads strong and elegant.' },
];
---

<section id="work" class="relative bg-ink text-warm-gray py-24 sm:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14" data-reveal>
      <div class="max-w-xl">
        <p class="eyebrow text-sand mb-6 flex items-center gap-3">
          <span class="inline-block w-9 h-px bg-sand rule-draw"></span>
          Our craft
        </p>
        <h2 class="font-display font-semibold text-4xl sm:text-5xl leading-[1.1] text-warm-gray">
          Built for visionary projects
        </h2>
      </div>
      <p class="max-w-sm text-warm-gray/60 text-base leading-relaxed">
        Steel and glass, engineered to fit and built to last — across every
        surface of a modern building.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5">
      {items.map((it, i) => (
        <figure
          class="group relative overflow-hidden bg-deep-teal aspect-[4/5]"
          data-reveal
          style={`--reveal-delay:${i * 120}ms`}
        >
          <img
            src={it.img}
            alt={it.label}
            class="absolute inset-0 w-full h-full object-cover duotone group-hover:scale-105 transition-transform duration-[900ms] ease-out"
            loading="lazy"
            width="1000"
            height="1200"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/25 to-transparent"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-white/10"></div>
          <figcaption class="absolute inset-x-0 bottom-0 p-6 sm:p-7">
            <span class="block w-8 h-px bg-sand mb-4 group-hover:w-14 transition-all duration-500"></span>
            <h3 class="font-display text-xl font-semibold text-warm-gray tracking-wide">{it.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-warm-gray/70">{it.note}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
