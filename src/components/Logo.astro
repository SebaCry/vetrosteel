---
interface Props {
  variant?: 'full' | 'mark';
  tone?: 'light' | 'dark';
  class?: string;
}
const { variant = 'full', tone = 'light', class: className = '' } = Astro.props;

const sizeClass = variant === 'full' ? 'h-40 sm:h-40 w-auto' : 'h-16 w-16';
const toneClass = tone === 'light' ? 'brightness-0 invert' : 'brightness-100';
---

<img
  src="/logo.png"
  alt="Vetro Steel"
  class={`shrink-0 object-contain ${sizeClass} ${toneClass} ${className}`}
  loading="eager"
  decoding="async"
/>
